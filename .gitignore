# Built artifacts — these are published as release assets, not committed
*.raw
*.raw.sha256
traceway-otel-agent

# Transpiled Ignition JSON — commit the Butane source, not the output
# This may contain secrets (SSH key, Traceway token) — never commit it
cfg/ignition.json

# The flatcar-install script is fetched on demand (make fetch-installer)
flatcar-install/flatcar-install
# Cached Flatcar image (downloaded on first provision, reused on subsequent runs)
flatcar-install/*.bz2
flatcar-install/*.sig
